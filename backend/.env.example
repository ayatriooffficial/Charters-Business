NODE_ENV=development
PORT=5000
MONGODB_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=30d
CORS_ORIGIN=http://localhost:3000

# Fixed Google Meet Link for Instant Calls
INSTANT_CALL_MEET_LINK=https://meet.google.com/your-meet-link

# Google SMTP Configuration
GOOGLE_EMAIL=your_gmail_address@gmail.com
GOOGLE_APP_PASSWORD=your_google_app_password

# Admin Email for Notifications
ADMIN_EMAIL=admin@chartersbusiness.com

# Firebase Admin SDK Configuration
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"
# OR provide the full JSON string
# FIREBASE_SERVICE_ACCOUNT='{"type": "service_account", ...}'
