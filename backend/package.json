{
  "name": "charters-business-backend",
  "version": "1.0.0",
  "description": "Production-ready Express + MongoDB backend for Charters Business",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write \"src/**/*.js\"",
    "lint:fix": "eslint src/**/*.js --fix"
  },
  "keywords": [
    "express",
    "mongodb",
    "rest-api",
    "backend",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@exortek/express-mongo-sanitize": "^1.1.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.6.1",
    "googleapis": "^171.4.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^7.1.0",
    "mongoose": "^8.19.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "next-bundle-analyzer": "^0.6.8",
    "nodemailer": "^7.0.13",
    "validator": "^13.15.15",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.0",
    "eslint": "^9.13.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.13",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0"
  }
}
